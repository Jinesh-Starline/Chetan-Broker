<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util"
     xmlns:netfx="http://wixtoolset.org/schemas/v4/wxs/netfx">
	<?define IsOfflineInstaller = "false" ?>

	<Bundle Name="Chetan Broker" Manufacturer="Chetan Broker"
		Version="1.0.0.0" UpgradeCode="F3E720C2-8B6B-406E-A666-31E0973CB148"
		IconSourceFile="..\Assets\appicon.ico">

		<BootstrapperApplication>
			<bal:WixInternalUIBootstrapperApplication />
		</BootstrapperApplication>
		

		<!--<WixVariable Id="WixStdbaLicenseUrl" Value="" />


		<BootstrapperApplication>
			<bal:WixStandardBootstrapperApplication
				Theme="hyperlinkSidebarLicense"
				ThemeFile="Theme.xml"
				LocalizationFile="Theme.wxl"
				LogoFile="..\Assets\appicon.ico"
				LogoSideFile="..\Assets\appicon.png"
				LicenseFile="..\Assets\licence.txt"
				SuppressOptionsUI="yes" />
		</BootstrapperApplication>-->
		
		
		<netfx:DotNetCoreSearch Id="DotNetVerFind"
		                        Variable="DOT_NET_VER"
		                        RuntimeType="desktop"
		                        Platform="x64"
		                        MajorVersion="8" />

		<Chain>
			<?if $(var.IsOfflineInstaller) = "true" ?>
			<ExePackage Id="Net8Offline"
						DisplayName="Microsoft .NET 8.0 Desktop Runtime (x64)"
						SourceFile="dotnet8-x64.exe"
						InstallArguments="/install /quiet /norestart"
						DetectCondition="DOT_NET_VER AND DOT_NET_VER &gt;= v8.0.0"
						Permanent="yes" />
			<?endif ?>

			<?if $(var.IsOfflineInstaller) = "false" ?>
			<ExePackage Id="Net8Online"
						DisplayName="Microsoft .NET 8.0 Desktop Runtime (x64)"
						SourceFile="dotnet8-x64.exe"
						DownloadUrl="https://aka.ms/dotnet/8.0/windowsdesktop-runtime-win-x64.exe"
						InstallArguments="/install /quiet /norestart"
						DetectCondition="DOT_NET_VER AND DOT_NET_VER &gt;= v8.0.0"
						Compressed="no"
						Permanent="yes" />
			<?endif ?>

			<MsiPackage SourceFile="$(var.Broker.Installer.TargetPath)" />
		</Chain>
	</Bundle>
</Wix>

