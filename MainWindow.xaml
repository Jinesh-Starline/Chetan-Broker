<Window x:Class="Chetan_Broker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Chetan Broker"
        WindowStartupLocation="CenterScreen"
        Height="450"
        Width="800">

    <Grid>

        <!-- LOGIN SECTION -->
        <Grid x:Name="LoginSection">

            <Border Width="350"
                    Padding="25"
                    CornerRadius="8"
                    BorderBrush="#DDD"
                    BorderThickness="1"
                    Background="White"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <StackPanel>

                    <TextBlock Text="Welcome"
                               Style="{StaticResource HeaderText}"
                               FontSize="18"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="Username"/>
                    <TextBox x:Name="txtUsername" Margin="0,5,0,10"/>

                    <TextBlock Text="Password"/>
                    <PasswordBox x:Name="txtPassword" Margin="0,5,0,15"/>
                    
                    <CheckBox x:Name="chkAutoLogin"
                          Content="Auto Login"
                          Margin="0,5,0,10"/>
                    
                    <Button Content="Login"
                            Height="35"
                            Click="Login_Click"/>

                </StackPanel>

            </Border>

        </Grid>


        <!-- MAIN SECTION -->
        <Grid x:Name="MainSection" Visibility="Collapsed">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Background="#2D2D30" Padding="15">

                <StackPanel x:Name="SidebarPanel">

                    <!-- Title -->
                    <TextBlock Text="Menu"
                        Foreground="White"
                        FontSize="16"
                        FontWeight="Bold"
                        Margin="0,0,0,20"/>

                    <Button Content="Home"
                        Height="40"
                        Margin="0,5"
                        Background="Transparent"
                        Foreground="White"
                        x:Name="btnHome"
                        BorderBrush="#3E3E42"
                        BorderThickness="1"
                        Click="ShowHome_Click"/>
                    
                    <!-- Party -->
                    <Button Content="Party"
                        Height="40"
                        Margin="0,5"
                        Background="Transparent"
                        Foreground="White"
                        x:Name="btnParty" 
                        BorderBrush="#3E3E42"
                        BorderThickness="1"
                        Click="ShowParty_Click"/>

                    <!-- Transaction -->
                    <Button Content="Transaction"
                        Height="40"
                        Margin="0,5"
                        Background="Transparent"
                        x:Name="btnTransaction" 
                        Foreground="White"
                        BorderBrush="#3E3E42"
                        BorderThickness="1"
                        Click="ShowTransaction_Click"/>

                    <Button Content="Reports"
                        Height="40"
                        Margin="0,5"
                        Background="Transparent"
                        Foreground="White"
                        x:Name="btnReports"
                        BorderBrush="#3E3E42"
                        BorderThickness="1"
                        Click="ShowReports_Click"/>

                </StackPanel>

            </Border>

            <!-- MAIN CONTENT AREA -->
            <Grid Grid.Column="1">

                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Border Background="#EEEEEE" Padding="10">

                    <DockPanel LastChildFill="True">

                        <!-- Right side (Account) -->
                        <Menu DockPanel.Dock="Right"
              VerticalAlignment="Center">
                            <MenuItem Header="👤">
                                <MenuItem Header="Change Password"
                          Click="ChangePassword_Click"/>
                                <MenuItem Header="Logout"
                          Click="Logout_Click"/>
                            </MenuItem>
                        </Menu>

                        <!-- Left side (Title) -->
                        <TextBlock Text="Chetan Broker"
                   Style="{StaticResource HeaderText}"
                   VerticalAlignment="Center"/>

                    </DockPanel>

                </Border>

                <!-- CONTENT -->
                <Border Grid.Row="1"
                        Padding="15">

                    <ContentControl x:Name="MainContent"/>

                </Border>

            </Grid>

        </Grid>

    </Grid>
</Window>