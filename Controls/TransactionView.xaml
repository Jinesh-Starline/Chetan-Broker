<UserControl x:Class="Chetan_Broker.Controls.TransactionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- FORM SECTION -->
        <Border BorderBrush="#DDD"
                BorderThickness="1"
                Padding="15"
                CornerRadius="5">

            <Grid>

                <!-- Better responsive layout -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Sender -->
                <TextBlock Text="Sender:"
                           Style="{StaticResource HeaderText}"
                           VerticalAlignment="Center"/>

                <ComboBox x:Name="cmbSenderParty"
                          DisplayMemberPath="Name"
                          Grid.Column="1"
                          SelectedValuePath="Id"
                          Margin="5"/>

                <!-- Receiver -->
                <TextBlock Text="Receiver:"
                           Grid.Column="2"
                           Style="{StaticResource HeaderText}"
                           VerticalAlignment="Center"/>

                <ComboBox x:Name="cmbReceiverParty"
                          DisplayMemberPath="Name"
                          Grid.Column="3"
                          SelectedValuePath="Id"
                          Margin="5"/>

                <!-- Date -->
                <TextBlock Text="Date:"
                           Grid.Row="1"
                           Style="{StaticResource HeaderText}"
                           VerticalAlignment="Center"/>

                <DatePicker x:Name="dpTransactionDate"
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="5"/>

                <!-- Amount -->
                <TextBlock Text="Amount:"
                           Grid.Row="1"
                           Grid.Column="2"
                           Style="{StaticResource HeaderText}"
                           VerticalAlignment="Center"/>

                <TextBox x:Name="txtTransactionAmount"
                         Grid.Row="1"
                         Grid.Column="3"
                         Margin="5"
                         PreviewTextInput="NumberOnly"
                         DataObject.Pasting="OnPaste"/>

                <!-- Brokerage -->
                <TextBlock Text="Brokerage:"
                           Grid.Row="2"
                           Style="{StaticResource HeaderText}"
                           VerticalAlignment="Center"/>

                <TextBox x:Name="txtBrokerageAmount"
                         Grid.Row="2"
                         Grid.Column="1"
                         Margin="5"
                         PreviewTextInput="NumberOnly"
                         DataObject.Pasting="OnPaste"/>

                <StackPanel Grid.Row="2"
                    Grid.Column="2"
                    Grid.ColumnSpan="2"
                    Orientation="Vertical"
                    HorizontalAlignment="Right"
                    Margin="5,15,0,0">

                     <Button Content="Add / Update"
                        Width="160"
                        Margin="0,0,0,10"
                        Click="AddTransaction_Click"/>

                    <Button Content="Delete"
                        Width="120"
                        Click="DeleteTransaction_Click"/>

                </StackPanel>

            </Grid>

        </Border>

        <!-- GRID SECTION -->
        <Border Grid.Row="1"
                Margin="0,20,0,0"
                BorderBrush="#DDD"
                BorderThickness="1"
                Padding="10"
                CornerRadius="5">

            <DataGrid x:Name="dgTransactions"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      SelectionChanged="dgTransactions_SelectionChanged"
                      RowHeight="30">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Sender"
                                        Binding="{Binding SenderName}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Receiver"
                                        Binding="{Binding ReceiverName}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Date"
                                        Binding="{Binding TransactionDate}"
                                        Width="130"/>

                    <DataGridTextColumn Header="Amount"
                                        Binding="{Binding Amount}"
                                        Width="120"/>

                    <DataGridTextColumn Header="Brokerage"
                                        Binding="{Binding Brokerage}"
                                        Width="120"/>
                </DataGrid.Columns>

            </DataGrid>

        </Border>

    </Grid>
</UserControl>