<UserControl x:Class="Chetan_Broker.Controls.ReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- FILTER -->
        <Border BorderBrush="#DDD"
                BorderThickness="1"
                Padding="15"
                CornerRadius="5">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Select Party:"
                   Style="{StaticResource HeaderText}"
                   VerticalAlignment="Center"/>

                <ComboBox x:Name="cmbParty"
                    Grid.Column="1"
                    DisplayMemberPath="Name"
                    SelectedValuePath="Id"
                    Margin="5"/>

                <Button Content="Load Report"
                    Grid.Column="2"
                    Width="120"
                    Margin="10,0,0,0"
                    Click="LoadReport_Click"/>

                <Button Content="Export PDF"
                    Grid.Column="3"
                    Width="120"
                    Margin="10,0,0,0"
                    Click="ExportPdf_Click"/>
            </Grid>
        </Border>

        <!-- GRID -->
        <!-- GRID -->
        <Border Grid.Row="1"
        Margin="0,20,0,0"
        BorderBrush="#DDD"
        BorderThickness="1"
        Padding="10"
        CornerRadius="5">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Data -->
                <DataGrid x:Name="dgReport"
                  AutoGenerateColumns="False"
                  IsReadOnly="True">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding TransactionDate}" Width="120"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="City" Binding="{Binding City}" Width="150"/>
                        <DataGridTextColumn Header="Amount" Binding="{Binding Amount}" Width="150"/>
                        <DataGridTextColumn Header="BagQuantity" Binding="{Binding BagQuantity}" Width="120"/>
                        <DataGridTextColumn Header="Remarks" Binding="{Binding Remarks, TargetNullValue=--, FallbackValue=--}" Width="120" />
                        <DataGridTextColumn Header="Brokerage" Binding="{Binding Brokerage}" Width="120"/>
                    </DataGrid.Columns>

                </DataGrid>

                <!-- Total -->
                <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">

                    <TextBlock Text="Total Brokerage:"
                       Style="{StaticResource HeaderText}"
                       Margin="0,0,10,0"/>

                    <TextBlock x:Name="txtTotalBrokerage"
                       Style="{StaticResource HeaderText}"/>

                </StackPanel>

            </Grid>

        </Border>


    </Grid>
</UserControl>