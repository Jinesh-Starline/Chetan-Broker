<UserControl x:Class="Chetan_Broker.Controls.PartyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Chetan_Broker.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- FORM -->
        <Border BorderBrush="#DDD" BorderThickness="1" Padding="15" CornerRadius="5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Party Name:"
                    VerticalAlignment="Center"
                    Margin="0,0,10,0"/>
                
                <TextBox x:Name="txtPartyName"
                     Width="250"
                     Margin="0,0,10,0"
                     VerticalAlignment="Center"/>

                <Button Content="Add Party"
                    Width="120"
                    Click="AddParty_Click"/>

                <Button Content="Update"
                    Grid.Column="2"
                    Width="120"
                    Margin="10,0,0,0"
                    Click="UpdateParty_Click"/>

                <Button Content="Delete"
                    Grid.Column="2"
                    Width="120"
                    Margin="10,0,0,0"
                    Click="DeleteParty_Click"/>

            </StackPanel>
        </Border>

        <!-- LIST -->
        <ListBox x:Name="lstParties"
             Grid.Row="1"
             SelectionChanged="lstParties_SelectionChanged"
             Margin="0,20,0,0"
             DisplayMemberPath="Name"/>

    </Grid>
</UserControl>
